# Supabase — created via supabase.com.

# Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Settings → Database.
# DATABASE_URL: the pooled (transaction-mode) connection string — used by
# the deployed application at runtime. Recommended for serverless
# deployments (e.g. Vercel) to avoid exhausting Postgres connections
# under concurrent invocations.
DATABASE_URL=

# DIRECT_URL: a migration-safe connection string — used only by Prisma's
# CLI (`prisma migrate`), never by the running application. Prisma's
# migration engine uses session-level advisory locks that the transaction
# pooler above does not support correctly, so this must be a different
# connection than DATABASE_URL.
#
# Prefer Supabase's direct database connection (IPv6) if the machine
# running the migration can reach it. If that environment cannot use
# Supabase's IPv6 direct endpoint, use the session-pooler connection
# string instead — never the transaction-pooler (runtime) connection
# above, which does not support migrations reliably regardless of network
# capability.
DIRECT_URL=

# The Executive Orchestrator's scheduler auth (Increment 7). Any random
# string — Vercel Cron sends it automatically as a bearer token once set
# in your deployment's environment variables.
CRON_SECRET=

# Optional. The Narrative Layer's LLM provider (lib/narrative/providers/claude.ts).
# Without it, the Cognitive Engine's own deterministic text is used — the
# Morning Brief works correctly either way.
ANTHROPIC_API_KEY=
