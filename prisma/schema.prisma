// Business Brain schema — Business Partner MVP Blueprint v1.0, Section 4.
// Deliberately minimal: only what the Morning Brief needs today.
// Every future memory layer (Asset 007) slots into this schema without restructuring it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
directUrl = env("DIRECT_URL")
}

model Business {
  id              String                 @id @default(cuid())
  ownerId         String                 @unique // Supabase auth user id — one Business per owner in v1
  name            String
  industry        String
  description     String?
  website         String?
  goals           Goal[]
  people          Person[]
  signals         Signal[]
  briefs          MorningBrief[]
  providerConfigs SignalProviderConfig[]
  signalSources   SignalSource[]
  confirmedColumnMappings ConfirmedColumnMapping[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  onboardingCompletedAt DateTime?
}

model Goal {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  description String
  priority    Int // owner-ranked, lower = higher priority
  createdAt   DateTime @default(now())
}

model Person {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name         String
  relationship String // customer | prospect | supplier | employee | partner
  email        String?
  company      String? // Recommendation 2, approved by Founder + CPO, 19 July 2026. Business Memory — knowledge only the owner can reliably provide, not extracted from Calendar or Gmail (which have no company field at all). Optional; owner-provided.
  notes        String?
  signals      Signal[]
  createdAt    DateTime @default(now())
}

// Signal, SignalProviderConfig, and MorningBrief are modeled now so migrations
// are stable across Increment 1–5, even though Increment 1 did not populate them.
// Increment 2 populates Signal via the Signal Provider pipeline (lib/signals).
model Signal {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  domain           String // calendar | email | tasks | crm | finance | proposals
  type             String
  occurredAt       DateTime
  personId         String?
  person           Person?  @relation(fields: [personId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payload          Json
  sourceProviderId String
  // Provider-supplied stable identifier (e.g. a Google Calendar event ID, or a
  // deterministic hash for seeded data). Makes ingestion idempotent regardless
  // of which provider — seeded or live — produced the signal. See DECISIONS.md.
  externalRef      String
  confidence       Float    @default(1.0)
  createdAt        DateTime @default(now())
  // Product Audit — F0: Signal Temporality, 22 July 2026 (Founder + CPO).
  // 'continuous' (default) | 'snapshot'. Existing signals (calendar, email)
  // are unaffected — the default preserves current behaviour exactly.
  temporality          String    @default("continuous")
  // Populated only when temporality === 'snapshot'. Staleness for a
  // snapshot signal is always derived from reportingPeriodEnd, never
  // acquisitionTime/occurredAt/createdAt — see lib/cognition/snapshotAge.ts.
  reportingPeriodStart DateTime?
  reportingPeriodEnd   DateTime?
  // SnapshotProvenance (lib/signals/types.ts) — extractionMethod,
  // sourceDocumentType, structurallyComplete. Attached by every
  // DocumentSignalExtractor; consulted by qualify.ts, never by Prioritise.
  provenance           Json?
  // Product Audit — F1: Aged Debtors/Creditors, 22 July 2026 (Founder +
  // CPO correction to F1 v1's flat provenance.sourceReference string,
  // insufficient as durable identity for upload history/traceability).
  // Nullable: only snapshot signals produced by a DocumentSignalExtractor
  // populate these; calendar/email signals never do.
  sourceId        String?
  source          SignalSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  sourceRowNumber Int?

  @@unique([businessId, externalRef])
}

// Product Audit — F1: Aged Debtors/Creditors, 22 July 2026 (Founder + CPO).
// The durable record of one upload/acquisition event — a business owner's
// CSV upload today, an accounting-platform sync later. Every resulting
// Signal references exactly one SignalSource via Signal.sourceId. Raw file
// bytes are deliberately not retained here (Founder/CPO decision) —
// checksum proves byte-identity for idempotency without storing content.
model SignalSource {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  documentType     String   // 'aged_debtors' | 'aged_creditors'
  // Recorded independently of documentType (Founder/CPO architectural
  // provisioning, 22 July 2026) — so a future Xero-backed 'aged_debtors'
  // source is a new acquisitionMethod value against the same documentType,
  // never a schema change. F1 always writes 'csv_upload'.
  acquisitionMethod    String
  originalFilename     String
  checksum             String    // sha256 of the raw upload — file-level idempotency, no raw-byte retention
  reportingDate        DateTime? // confirmed "as at" date; null while status = 'pending_confirmation'
  fileLevelCurrency    String?   // set only when no row-level currency applies — see the extractor
  // Stable identifier from an API-backed source (e.g. a future Xero
  // document id) — provisioned now (Founder/CPO, 22 July 2026), always
  // null for F1's CSV uploads, since no such identifier exists for them.
  externalSourceRef    String?
  totalRowCount        Int
  processedRowCount    Int
  excludedRowCount     Int
  reconciliationResult String    // 'passed' | 'failed' | 'unavailable'
  status               String    // 'pending_confirmation' | 'processing' | 'completed' | 'rejected'
  createdAt            DateTime  @default(now())
  signals              Signal[]

  @@unique([businessId, checksum])
}

model SignalProviderConfig {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  domain     String
  providerId String
  config     Json?

  @@unique([businessId, domain])
}

// Increment 3 (Cognitive Engine v1) populates this model for the first time.
// Increment 4 adds `tier` and `message` for the Executive Honesty model: a
// MorningBrief is always exactly one of three tiers (see
// lib/cognition/types.ts MorningBriefResult), so the fields below the tier
// column are nullable — which fields are populated depends on which tier
// this row is. `recommendation` is the one-sentence executive summary;
// `recommendedAction` is the concrete next step (confident_recommendation
// only); `reasoning` is the "why this matters" narrative, grounded in
// `supportingSignalIds`; `message` is the all_clear tier's only content.
// Kept as distinct fields (rather than one combined string) so the UI, and
// any future channel — email digest, voice brief — can render each part
// appropriately. See DECISIONS.md.
model MorningBrief {
  id                  String    @id @default(cuid())
  businessId          String
  business            Business  @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  generatedAt         DateTime  @default(now())
  tier                String // 'confident_recommendation' | 'low_confidence_insight' | 'all_clear'
  recommendation      String? // executive summary — one sentence. Null only for all_clear.
  reasoning           String? // why this matters, referencing supporting signals. Null only for all_clear.
  recommendedAction   String? // the concrete next action to take. Only present for confident_recommendation.
  confidence          Float? // null only for all_clear — there is nothing to be confident or unconfident about.
  supportingSignalIds String[] @default([]) // empty for all_clear.
  message             String? // all_clear tier's plain statement. Null for the other two tiers.
  ownerResponse       String? 
  continuityNote      String? // Executive Presence Audit, 19 July 2026 — an optional, timeless sentence acknowledging what's been added to Business Memory since the previous brief. Never present for all_clear (Business Memory Reflection already covers that tier fully). Null whenever nothing genuinely changed.
  recognisedSignals   Json? // Production Implementation Contract, Point 6 (Evidence Chain), 20 July 2026. Every signal that qualified (see lib/cognition/qualify.ts) but did not win the recommendation, with its grounding reason and matched Person/Goal id — so "Recognised Signals" is inspectable after the fact, not just used in-memory for one generation. Array of {signalId, reason, matchedPersonId?, matchedGoalId?}. Null/empty when nothing else qualified.
}

// Multi-format CSV Understanding — Implementation Plan, 22 July 2026
// (Founder + CPO). Confirmed Mapping Memory (Founder Decision 1): once an
// owner confirms a column's meaning for a given business and source
// format, Business Partner remembers it — future uploads from the same
// source never ask again. Owner-confirmed understanding always takes
// precedence over inference and is never silently overwritten
// (Refinement 2) — a conflicting future upload is a new conversation
// with the owner, not an automatic replacement.
model ConfirmedColumnMapping {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  documentType String   // 'aged_debtors' | 'aged_creditors'
  // Refinement 1: an internal implementation detail, not a long-term
  // product contract. V1 is a hash of the normalised header set. This
  // may evolve (e.g. incorporating column count or structural patterns)
  // if real evidence shows header names alone are insufficient — this
  // model's durability as a concept does not depend on the signature
  // algorithm staying the same.
  sourceSignature String
  // Raw header name -> canonical field name. Only ever written once a
  // column has been explicitly confirmed by the owner — never populated
  // speculatively.
  columnMapping Json
  confirmedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([businessId, documentType, sourceSignature])
}
