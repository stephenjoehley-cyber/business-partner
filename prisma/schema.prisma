// Business Brain schema — Business Partner MVP Blueprint v1.0, Section 4.
// Deliberately minimal: only what the Morning Brief needs today.
// Every future memory layer (Asset 007) slots into this schema without restructuring it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
directUrl = env("DIRECT_URL")
}

model Business {
  id              String                 @id @default(cuid())
  ownerId         String                 @unique // Supabase auth user id — one Business per owner in v1
  name            String
  industry        String
  description     String?
  website         String?
  goals           Goal[]
  people          Person[]
  signals         Signal[]
  briefs          MorningBrief[]
  providerConfigs SignalProviderConfig[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  onboardingCompletedAt DateTime?
}

model Goal {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  description String
  priority    Int // owner-ranked, lower = higher priority
  createdAt   DateTime @default(now())
}

model Person {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name         String
  relationship String // customer | prospect | supplier | employee | partner
  email        String?
  company      String? // Recommendation 2, approved by Founder + CPO, 19 July 2026. Business Memory — knowledge only the owner can reliably provide, not extracted from Calendar or Gmail (which have no company field at all). Optional; owner-provided.
  notes        String?
  signals      Signal[]
  createdAt    DateTime @default(now())
}

// Signal, SignalProviderConfig, and MorningBrief are modeled now so migrations
// are stable across Increment 1–5, even though Increment 1 did not populate them.
// Increment 2 populates Signal via the Signal Provider pipeline (lib/signals).
model Signal {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  domain           String // calendar | email | tasks | crm | finance | proposals
  type             String
  occurredAt       DateTime
  personId         String?
  person           Person?  @relation(fields: [personId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payload          Json
  sourceProviderId String
  // Provider-supplied stable identifier (e.g. a Google Calendar event ID, or a
  // deterministic hash for seeded data). Makes ingestion idempotent regardless
  // of which provider — seeded or live — produced the signal. See DECISIONS.md.
  externalRef      String
  confidence       Float    @default(1.0)
  createdAt        DateTime @default(now())

  @@unique([businessId, externalRef])
}

model SignalProviderConfig {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  domain     String
  providerId String
  config     Json?

  @@unique([businessId, domain])
}

// Increment 3 (Cognitive Engine v1) populates this model for the first time.
// Increment 4 adds `tier` and `message` for the Executive Honesty model: a
// MorningBrief is always exactly one of three tiers (see
// lib/cognition/types.ts MorningBriefResult), so the fields below the tier
// column are nullable — which fields are populated depends on which tier
// this row is. `recommendation` is the one-sentence executive summary;
// `recommendedAction` is the concrete next step (confident_recommendation
// only); `reasoning` is the "why this matters" narrative, grounded in
// `supportingSignalIds`; `message` is the all_clear tier's only content.
// Kept as distinct fields (rather than one combined string) so the UI, and
// any future channel — email digest, voice brief — can render each part
// appropriately. See DECISIONS.md.
model MorningBrief {
  id                  String    @id @default(cuid())
  businessId          String
  business            Business  @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  generatedAt         DateTime  @default(now())
  tier                String // 'confident_recommendation' | 'low_confidence_insight' | 'all_clear'
  recommendation      String? // executive summary — one sentence. Null only for all_clear.
  reasoning           String? // why this matters, referencing supporting signals. Null only for all_clear.
  recommendedAction   String? // the concrete next action to take. Only present for confident_recommendation.
  confidence          Float? // null only for all_clear — there is nothing to be confident or unconfident about.
  supportingSignalIds String[] @default([]) // empty for all_clear.
  message             String? // all_clear tier's plain statement. Null for the other two tiers.
  ownerResponse       String? 
  continuityNote      String? // Executive Presence Audit, 19 July 2026 — an optional, timeless sentence acknowledging what's been added to Business Memory since the previous brief. Never present for all_clear (Business Memory Reflection already covers that tier fully). Null whenever nothing genuinely changed.
}
